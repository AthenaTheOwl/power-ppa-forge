{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/power-ppa-forge/scenario.schema.json",
  "title": "Power PPA Forge scenario",
  "type": "object",
  "required": ["scenario_id", "schema_version", "asset", "auction", "offtakers", "capital_case"],
  "properties": {
    "scenario_id": {"type": "string"},
    "schema_version": {"type": "string"},
    "asset": {
      "type": "object",
      "required": ["name", "technology", "capacity_mw", "capacity_factor", "commercial_operation_year", "target_dscr", "project_cost_usd_billion"],
      "properties": {
        "name": {"type": "string"},
        "technology": {"type": "string"},
        "capacity_mw": {"type": "number", "exclusiveMinimum": 0},
        "capacity_factor": {"type": "number", "exclusiveMinimum": 0},
        "commercial_operation_year": {"type": "integer"},
        "target_dscr": {"type": "number", "exclusiveMinimum": 0},
        "project_cost_usd_billion": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "auction": {
      "type": "object",
      "required": ["mechanism", "tranche_options_mw", "complementarity_weight"],
      "properties": {
        "mechanism": {"type": "string"},
        "tranche_options_mw": {
          "type": "array",
          "items": {"type": "number", "exclusiveMinimum": 0},
          "minItems": 1
        },
        "complementarity_weight": {"type": "number", "exclusiveMinimum": 0}
      }
    },
    "offtakers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "display_name", "max_capacity_mw", "bid_price_per_mwh", "load_shape"],
        "properties": {
          "id": {"type": "string"},
          "display_name": {"type": "string"},
          "max_capacity_mw": {"type": "number", "exclusiveMinimum": 0},
          "bid_price_per_mwh": {"type": "number", "exclusiveMinimum": 0},
          "load_shape": {
            "type": "array",
            "items": {"type": "number", "exclusiveMinimum": 0},
            "minItems": 24,
            "maxItems": 24
          }
        }
      }
    },
    "capital_case": {
      "type": "object",
      "required": ["baseline", "bilateral_nda_required_equity_share", "bounded_leak_required_equity_share"],
      "properties": {
        "baseline": {"type": "string"},
        "bilateral_nda_required_equity_share": {"type": "number", "exclusiveMinimum": 0},
        "bounded_leak_required_equity_share": {"type": "number", "exclusiveMinimum": 0}
      }
    }
  }
}
